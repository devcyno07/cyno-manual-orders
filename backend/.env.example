# ── Bank Details ─────────────────────────────
BANK_NAME=Dutch-Bangla Bank Limited
BANK_ACCOUNT_HOLDER=MediCare Pharmacy Ltd.
BANK_ACCOUNT_NUMBER=1051234567891
BANK_ROUTING=090268521
BANK_SWIFT=DBBLBDDH
BANK_BRANCH=Gulshan Branch, Dhaka
