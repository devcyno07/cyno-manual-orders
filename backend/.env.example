# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/medicare-pharmacy

# ── Google Sheets ────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEETS_API_KEY=your_google_api_key_here
